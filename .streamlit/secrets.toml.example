# Copy this file to .streamlit/secrets.toml (gitignored) and fill in.
# Generate a fresh signing key:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"

[auth]
signing_key = "REPLACE_WITH_A_LONG_RANDOM_STRING"

# DEV ONLY: skip the sign-in screen entirely. Anyone reaching the URL gets in.
# Remove these or set bypass = false before deploying anywhere shared.
# bypass = true
# bypass_as = "dev@adres.ae"

[app]
# Public URL where the dashboard runs. Magic links are built from this.
base_url = "http://localhost:8501"

# Where the dashboard fetches the tickets parquet at startup. Only required
# when running on a host that doesn't have data/tickets.parquet locally
# (i.e. Streamlit Cloud). For local dev, generate the parquet with
# `python preprocess.py` and this section can stay commented out.
# [data]
# repo  = "<owner>/<private-data-repo>"
# path  = "tickets.parquet"
# ref   = "main"
# token = "<github fine-grained PAT with 'contents: read' on the data repo>"

[smtp]
# DEV MODE: leave dev_print_only = true to skip real email sending —
# the magic link will be printed in the server console instead. Great
# for local testing without SMTP credentials.
dev_print_only = true

# PRODUCTION: set dev_print_only = false and fill the real SMTP creds.
# host = "smtp.office365.com"
# port = 587
# use_ssl = false   # use STARTTLS instead of SMTP_SSL
# user = "noreply@adres.ae"
# password = "<app password or smtp secret>"
# from = "AccessRP Dashboard <noreply@adres.ae>"
